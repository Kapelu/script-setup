#!/bin/bash
# ╔════════════════════════════════════════════════════╗
# │ clonar – Herramienta para clonar repositorios Git  │
# │ Versión: 3.5                                       │
# │ Autor: Daniel Calderon - Kapelu                    │
# │ Fecha: 02/03/2026                                  │
# │ WebSite: https://danielcalderon.vercel.app/        │
# ╚════════════════════════════════════════════════════╝
verde='\033[33m'
amarillo='\033[34m'
azul='\033[35m'
reset='\033[0m'

clear
echo ''
echo -e "$azul Repositorio a Clonar:$reset \c "
read repo
echo ''
git clone "$repo" --depth 1
echo ''
echo ''
echo -e "$verde Repositorio creado con éxito !!! $reset"
echo ''
echo ''
