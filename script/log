#!/usr/bin/env bash
# ╔════════════════════════════════════════════════════╗
# │ Logging Helper para kpsetup de Ubuntu              │
# │ Versión: 4.0                                       │
# │ Autor: Daniel Calderon - Kapelu                    │
# │ Fecha: 19-02-2026                                  │
# │ WebSite: https://danielcalderon.vercel.app/        │
# │ Github: https://github.com/Kapelu                  │
# ╚════════════════════════════════════════════════════╝
# ╔════════════════════════════════════════════════════╗
# │ Uso:                                               │
# │ log_info "Iniciando kpsetup..."                    │
# │ log_run "Instalando dependencias..."               │ 
# │ log_verify "Node.js" node -v                       │
# │ log_verify "npm" npm -v                            │
# │ log_ok "Instalación completada"                    │
# │ log_warn "Algunos archivos quedaron sin usar"      │
# │ log_error "Se detectaron errores menores"          │
# │                                                    │
# │ Salida en consola:                                 │
# │ 🟩 Iniciando kpsetup...                            │
# │ ⚙️ Instalando dependencias...                      │
# │ ✔️ Node.js version: 20.2.0                         │
# │ ⛔ npm no disponible                               │
# │ ✅ Instalación completada                          │
# │ ⚠️ Algunos archivos quedaron sin usar              │
# │ ❌ Se detectaron errores menores                   │
# ╚════════════════════════════════════════════════════╝
# Iconos
ICON_INFO="🟢​ "
ICON_OK="✅ "
ICON_WARN="⚠️ "
ICON_ERROR="❌ "
ICON_RUN="⚙️ "
ICON_VERIFY="✔️ "
ICON_VERIFAIL="⛔ "

# Log file 
LOG_FILE="${LOG_FILE:-}" 

# Core print (sin label)
_print() {
  local color="$1"
  local icon="$2"
  local msg="$3"
  # Imprime en consola
  printf "%b\n" "${COLOR[$color]}${icon}${COLOR[reset]} ${msg}"
  # También escribe a log file si está definido
  if [[ -n "$LOG_FILE" ]]; then
    # Quita los códigos ANSI para el log
    local clean_msg
    clean_msg=$(echo -e "${msg}" | sed 's/\x1B\[[0-9;]*[mK]//g')
    echo "${icon} ${clean_msg}" >>"$LOG_FILE"
  fi
}
# Logs básicos
log_ok()    { _print "ok"    "$ICON_OK"    "$1"; }
log_error() { _print "error" "$ICON_ERROR" "$1"; }
log_warn()  { _print "warn"  "$ICON_WARN"  "$1"; }
log_info()  { _print "info"  "$ICON_INFO"  "$1"; }
log_run()   { _print "blue"  "$ICON_RUN"   "$1"; }
# log_verify
log_verify() {
  local name="$1"
  shift
  local output
  output=$("$@" 2>/dev/null)
  if [ $? -ne 0 ] || [ -z "$output" ]; then
    _print "error" "$ICON_VERIFAIL" "$name no disponible"
    return 1
  fi
  _print "ok" "$ICON_VERIFY" "$name version: ${COLOR[bold]}$output${COLOR[reset]}"
}
# Manejo de errores global
error() {
  log_error " ⚠️ ERROR EN LÍNEA $1. Revisar log: $LOG_FILE"
  exit 1
}
trap 'error $LINENO' ERR