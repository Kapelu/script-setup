print_banner() {
  local msg="$1"
  printf "%b\n" "${COLOR[yellow]}════════════════════════════════════════════════════${COLOR[reset]}"
  printf "%b\n" "$msg"
  printf "%b\n" "${COLOR[yellow]}════════════════════════════════════════════════════${COLOR[reset]}"
  printf "\n"
}

logo() {
  printf "%b\n" "${COLOR[green]}"
  cat << "EOF"
██   ██  ██████   ███████  ███████  ████████  ██    ██  ██████
██  ██   ██   ██  ██       ██          ██     ██    ██  ██   ██
█████    ██████   ███████  █████       ██     ██    ██  ██████
██  ██   ██            ██  ██          ██      ██  ██   ██
██   ██  ██       ███████  ███████     ██       ████    ██
EOF
  printf "%b\n" "${COLOR[reset]}"
}
