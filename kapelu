  printf "%b%-40s%b\n" "        ${COLOR[bold]}${COLOR[italic]}${COLOR[warn]}GPU:${COLOR[reset]}${COLOR[italic]}${COLOR[gray]} $(GET_OSINFO gpu)"
  printf "%b%-40s%b\n" "        ${COLOR[bold]}${COLOR[italic]}${COLOR[warn]}RAM:${COLOR[reset]}${COLOR[italic]}${COLOR[gray]} $(GET_OSINFO ram)"
  printf "%b%-40s%b\n" "        ${COLOR[bold]}${COLOR[italic]}${COLOR[warn]}Disk:${COLOR[reset]}${COLOR[italic]}${COLOR[gray]} $(GET_OSINFO disk)"
  printf "%s\n" ""
  printf "%b%-40s%b\n" "      	 ${COLOR[ok]}📅 $(datetime)${COLOR[reset]}"
  printf "%b%-40s%b\n" "      	 ${COLOR[ok]}⚠️  Info guardada en $HOME/OS_Info.md${COLOR[reset]}"
	printf "%s\n" ""
  printf "      	    Presioná SPACE para continuar..." >&3
	read -n 1 -s -r </dev/tty
	} >&3
}

