#* Valida si la distro es UBUNTU
VALIDAR_DISTRO(){
  log_print info "Validando distribución..."
  sleep 5

  if [ -f /etc/os-release ]; then
    . /etc/os-release
  else
    clear >&3
    print_banner "⛔ No se pudo detectar la Distro‼️"
    sleep 3
    exit 1
  fi

  case "$ID" in
    ubuntu|debian|linuxmint|pop|zorin|elementary|neon)
      log_print ok "Distro soportada: $ID"
      sleep 2
      log_print info "Iniciando sistema..."
      sleep 3
      ;;
    *)
      clear >&3
      print_banner "⛔ Distro no soportada: $ID"
      sleep 3
      exit 1
      ;;
  esac
}
#* Funcion que actualiza APT
UPDATE(){
	log_print info "Actualizando sistema..."
	if ! apt-get update; then
		log_print verifail "Error en apt-get update"
    return 1
  fi
  if ! apt-get dist-upgrade -y; then
    log_print "Error en dist-upgrade"
    return 1
  fi
  log_print ok "Sistema actualizado correctamente."
}
#* Funcion de limpieza del sistema
CLEAN_SYSTEM() {
    log_print info "🧹 Iniciando limpieza del sistema..."
    # Limpiar paquetes innecesarios
    log_print ok "➤ Eliminando paquetes huérfanos..."
    apt-get autoremove -y
    # Limpiar caché de paquetes descargados
    log_print ok "➤ Limpiando caché de APT..."
    apt-get clean
    apt-get autoclean
    # Limpiar logs antiguos
    log_print ok "➤ Limpiando logs antiguos..."
    journalctl --vacuum-time=7d
    # Limpiar miniaturas (thumbnails)
    log_print ok "➤ Eliminando caché de miniaturas..."
    rm -rf "$USER_HOME/.cache/thumbnails/"*
    # Limpiar caché de usuario
    log_print ok "➤ Limpiando caché del usuario..."
    rm -rf "$USER_HOME/.cache/"*
    # Limpiar paquetes snap si existen
    if command -v snap >/dev/null 2>&1; then
        log_print ok "➤ Limpiando versiones antiguas de Snap..."
        snap list --all | awk '/disabled/{print $1, $3}' | while read snapname revision; do
            snap remove "$snapname" --revision="$revision"
        done
    fi
		# Eliminar paquetes en estado "rc" (residuos de configs)
		log_print ok "➤ Eliminando paquetes residuales..."
		dpkg -l | awk '/^rc/ { print $2 }' | xargs -r apt-get purge -y
    log_print " Limpieza completada."
		sleep 3
}
#* Función full update que llama a update_system y agrega Snap, Flatpak y firmware
FULL_UPDATE() {
    # Llamada a la función UPDATE
    UPDATE || return 1
    # Snap
    if command -v snap >/dev/null 2>&1; then
        log_print info "➤ Actualizando paquetes Snap..."
        snap refresh 2>/dev/null
    fi
    # Flatpak
    if command -v flatpak >/dev/null 2>&1; then
        log_print info "➤ Actualizando paquetes Flatpak..."
        flatpak update -y 2>/dev/null
    fi
    # Firmware (solo si es UEFI) / Microcode
    if [ -d /sys/firmware/efi ]; then
        if command -v fwupdmgr >/dev/null 2>&1; then
            log_print info "➤ Actualizando firmware (UEFI)..."
            fwupdmgr refresh >/dev/null 2>&1
            fwupdmgr update >/dev/null 2>&1
        fi
    else
        log_print warn "➤ Sistema en modo Legacy BIOS, se omite firmware."
    fi
    log_print ok "Actualización completa finalizada."
}
#* INSTALL_SNAP: Instala paquetes snap declarados en SNAP_TOOLS
INSTALL_SNAP(){
  log_print info "Instalando paquetes snap desde SNAP_TOOLS..."

  if ! command -v snap >/dev/null 2>&1; then
    log_print warn "snap no está instalado. Instalando snapd..."
    apt-get update -y
    apt-get install -y snapd
    systemctl enable --now snapd.socket
    ln -sf /var/lib/snapd/snap /snap
  else
    log_print ok "snap disponible"
  fi

  log_print info "Obteniendo lista de snaps instalados..."
  local installed
  installed="$(snap list | awk 'NR>1{print $1}')"

  local pkg
  for pkg in "${SNAP_TOOLS[@]}"; do
    if echo "$installed" | grep -qx "$pkg"; then
      log_print ok "$pkg ya está instalado"
    else
      log_print info "Instalando $pkg..."
      if snap install "$pkg"; then
        log_print ok "$pkg instalado ✔"
      else
        log_print error "Error instalando $pkg"
      fi
    fi
  done

  log_print ok "Instalación de paquetes SNAP finalizado"
}
#* INSTALL_APT: Instala paquetes usando APT_TOOLS
INSTALL_APT() {
  local pkg
  log_print info "Instalando paquetes desde APT_TOOLS..."

  for pkg in "${APT_TOOLS[@]}"; do
    if ! dpkg -s "$pkg" &>/dev/null; then
      log_print run "Instalando paquete: $pkg..."
      
      if ! apt-get install -y "$pkg"; then
        log_print warn "Paquete defectuoso: $pkg. Intentando desinstalar..."
        apt-get remove -y "$pkg" 2>/dev/null
      else
        log_print ok "Instalado correctamente: $pkg"
      fi
    else
      log_print info "Ya está instalado: $pkg"
    fi
  done
  log_print ok "Instalación de pauqetes APT finalizado"
}
#* INSTALL_BRAVE: Instala Brave
INSTALL_BRAVE() {
  log_print run "Instalando Brave Browser..."
  # Asegurar curl
  if ! dpkg -s curl &>/dev/null; then
    log_print run "Instalando dependencia: curl..."
    apt-get update -y || {
      log_print warn "Fallo en apt-get update"
      return 1
    }
    apt-get install -y curl || {
      log_print warn " No se pudo instalar curl"
      return 1
    }
  fi
  # LIMPIEZA PREVIA (clave para evitar conflicto Signed-By)
  log_print run "Limpiando configuraciones previas de Brave..."
  rm -f /etc/apt/sources.list.d/brave-browser*
  rm -f /usr/share/keyrings/brave-browser-archive-keyring.gpg
  rm -f /etc/apt/keyrings/brave-browser-archive-keyring.gpg
  # Crear directorio estándar si no existe
  mkdir -p /usr/share/keyrings
  # Keyring
  log_print run "Descargando keyring de Brave..."
  curl -fsSLo /usr/share/keyrings/brave-browser-archive-keyring.gpg \
    https://brave-browser-apt-release.s3.brave.com/brave-browser-archive-keyring.gpg || {
      log_print warn "Error descargando keyring"
      return 1
    }
  # Repo
  log_print run "Agregando repositorio Brave..."
  curl -fsSLo /etc/apt/sources.list.d/brave-browser-release.sources \
    https://brave-browser-apt-release.s3.brave.com/brave-browser.sources || {
      log_print warn "Error agregando repositorio"
      return 1
    }
  # Update + install
  log_print run "Actualizando repositorios..."
  apt-get update -y || {
    log_print warn "Fallo en apt-get update"
    return 1
  }
  log_print run "Instalando brave-browser..."
  apt-get install -y brave-browser || {
    log_print warn "No se pudo instalar Brave"
    return 1
  }
  log_print ok "Brave instalado correctamente"
}
#* INSTALL_GOOGLE: Instala Google Chrome
INSTALL_GOOGLE() {
	log_print run "Instalación de Google Chrome..."
  rm -f /etc/apt/sources.list.d/google-chrome.list
  rm -f /etc/apt/keyrings/google-chrome.gpg
  log_print run "Agregando clave oficial (keyring)..."
  mkdir -p /etc/apt/keyrings
  curl -fsSL https://dl.google.com/linux/linux_signing_key.pub \
    | gpg --dearmor -o /etc/apt/keyrings/google-chrome.gpg
  chmod 644 /etc/apt/keyrings/google-chrome.gpg
  log_print run "Agregando repositorio..."
  echo "deb [arch=amd64 signed-by=/etc/apt/keyrings/google-chrome.gpg] http://dl.google.com/linux/chrome/deb/ stable main" \
    > /etc/apt/sources.list.d/google-chrome.list
  log_print run "Actualizando repositorios..."
  apt-get update
  log_print run "Instalando Google Chrome..."
  apt-get install -y google-chrome-stable
  log_print ok "Google Chrome instalado correctamente"
}
#* REMOVE_FIREFOX: Desintala completamente Firefox del sistema, sin dejar residuos.
REMOVE_FIREFOX(){
  log_print info "Detectando instalación de Firefox..."

  local found=false

  # --- SNAP ---
  if command -v snap >/dev/null 2>&1 && snap list 2>/dev/null | grep -q "^firefox"; then
    log_print info "Firefox detectado como SNAP"
    snap remove --purge firefox
    rm -rf /var/snap/firefox /var/lib/snapd/snaps/firefox*
    found=true
  fi

  # --- APT ---
  if dpkg -s firefox >/dev/null 2>&1; then
    log_print info "Firefox detectado como paquete APT"
    apt-get purge -y firefox
    apt-get autoremove -y --purge
    rm -f /etc/apt/sources.list.d/*firefox*
    found=true
  fi

  # --- FLATPAK ---
  if command -v flatpak >/dev/null 2>&1 && flatpak list 2>/dev/null | grep -q "org.mozilla.firefox"; then
    log_print info "Firefox detectado como FLATPAK"
    flatpak uninstall -y org.mozilla.firefox --delete-data
    rm -rf /var/lib/flatpak/app/org.mozilla.firefox
    found=true
  fi

  if [ "$found" = false ]; then
    log_print warn "Firefox no está instalado por apt, snap ni flatpak"
  fi

  log_print info "Eliminando residuos..."

  # --- USERS ---
  local dir
  for dir in /home/* /root; do
    rm -rf "$dir/.mozilla" \
           "$dir/.cache/mozilla" \
           "$dir/.config/firefox"
  done

  # --- BINARIOS ---
  rm -f /usr/bin/firefox /usr/local/bin/firefox

  # --- SYSTEM ---
  rm -rf /usr/lib/firefox \
         /usr/lib/firefox-esr \
         /usr/share/firefox \
         /etc/firefox

  log_print ok "Firefox eliminado completamente"
}
#* INSTALL_CODE: Instala vscode desde el repositorio de APT
INSTALL_CODE() {
  log_print INFO "Instalando Visual Studio Code (repo oficial Microsoft)..."

  local KEYRING="/etc/apt/keyrings/microsoft.gpg"
  local SOURCE_LIST="/etc/apt/sources.list.d/vscode.list"

  # --- Limpieza previa ---
  log_print INFO "Limpiando instalaciones previas de VS Code..."
  rm -f "$SOURCE_LIST"
  rm -f "$KEYRING"

  # --- Dependencias ---
  log_print RUN "Instalando dependencias necesarias..."
  apt-get update -y || { log_print ERROR "apt update falló"; return 1; }
  apt-get install -y software-properties-common apt-transport-https wget gpg || {
    log_print ERROR "Fallo instalando dependencias"
    return 1
  }

  # --- Keyring ---
  log_print RUN "Importando clave GPG (keyring)..."
  mkdir -p /etc/apt/keyrings
  wget -qO- https://packages.microsoft.com/keys/microsoft.asc | gpg --dearmor > "$KEYRING" || {
    log_print ERROR "No se pudo importar la clave GPG"
    return 1
  }
  chmod 644 "$KEYRING"

  # --- Repo ---
  log_print RUN "Agregando repositorio VS Code..."
  echo "deb [arch=amd64 signed-by=$KEYRING] https://packages.microsoft.com/repos/vscode stable main" > "$SOURCE_LIST"

  # --- Instalación ---
  log_print RUN "Actualizando e instalando VSCode..."
  apt-get update -y || { log_print ERROR "apt update falló"; return 1; }

  if ! apt-get install -y code; then
    log_print ERROR "Error instalando VS Code"
    return 1
  fi

  # --- Verificación ---
  #log_print ok "VS Code" code -version

  log_print OK "VS Code instalado correctamente"
}
#* INSTALL_SUBLIMETEXT: Instala sublime text desde el repositorio de APT
INSTALL_SUBLIMETEXT() {
  log_print INFO "Instalando Sublime Text (APT)..."

  local KEYRING="/etc/apt/keyrings/sublimehq-pub.asc"
  local SOURCE_FILE="/etc/apt/sources.list.d/sublime-text.sources"

  # --- LIMPIEZA PREVIA ---
  log_print INFO "Eliminando configuraciones previas..."
  rm -f "$SOURCE_FILE"
  rm -f "$KEYRING"

  # --- PREPARAR DIRECTORIO KEYRINGS ---
  install -d -m 0755 /etc/apt/keyrings

  # --- IMPORTAR CLAVE GPG ---
  log_print INFO "Importando clave GPG..."
  wget -qO - https://download.sublimetext.com/sublimehq-pub.gpg \
    | tee "$KEYRING" > /dev/null

  chmod 0644 "$KEYRING"

  # --- AGREGAR REPOSITORIO (STABLE) ---
  log_print INFO "Agregando repositorio APT (stable)..."
  cat > "$SOURCE_FILE" <<EOF
  Types: deb
  URIs: https://download.sublimetext.com/
  Suites: apt/stable/
  Signed-By: $KEYRING
EOF

  # --- ACTUALIZAR E INSTALAR ---
  log_print INFO "Actualizando índices APT..."
  apt-get update -y

  log_print INFO "Instalando Sublime Text..."
  if apt-get install -y sublime-text; then
    log_print OK "Sublime Text instalado correctamente"
  else
    log_print ERROR "Error al instalar Sublime Text"
    return 1
  fi
}
#* INSTALL_PROTONVPN: Instala protonVPN desde el repositorio de APT
INSTALL_PROTONVPN() {
  log_print INFO "Instalando Proton VPN (APT repo oficial)..."

  local TMP_DEB="/tmp/protonvpn-stable-release.deb"
  local EXPECTED_SHA="0b14e71586b22e498eb20926c48c7b434b751149b1f2af9902ef1cfe6b03e180"

  # --- LIMPIEZA PREVIA ---
  log_print INFO "Limpiando instalaciones previas..."
  apt purge -y protonvpn protonvpn-cli proton-vpn-gnome-desktop 2>/dev/null || true
  rm -f /etc/apt/sources.list.d/protonvpn*.list
  rm -f /etc/apt/sources.list.d/protonvpn*.sources
  rm -f /usr/share/keyrings/protonvpn* 2>/dev/null || true

  # --- DESCARGA ---
  log_print INFO "Descargando paquete del repositorio..."
  wget -q -O "$TMP_DEB" \
    https://repo.protonvpn.com/debian/dists/stable/main/binary-all/protonvpn-stable-release_1.0.8_all.deb

  # --- VERIFICACIÓN SHA256 ---
  log_print INFO "Verificando integridad del paquete..."
  echo "${EXPECTED_SHA}  ${TMP_DEB}" | sha256sum --check --status
  if [ $? -ne 0 ]; then
    log_print ERROR "Checksum inválido. Abortando instalación."
    rm -f "$TMP_DEB"
    return 1
  fi

  # --- INSTALACIÓN DEL REPO ---
  log_print INFO "Instalando repositorio Proton VPN..."
  dpkg -i "$TMP_DEB"
  apt update

  # --- INSTALACIÓN APP ---
  log_print INFO "Instalando aplicación Proton VPN..."
  apt install -y proton-vpn-gnome-desktop

  # --- OPCIONAL: TRAY ICON ---
  log_print INFO "Instalando soporte para icono en bandeja (opcional)..."
  apt install -y gnome-shell-extension-appindicator gnome-shell-extension-prefs

  # --- LIMPIEZA ---
  rm -f "$TMP_DEB"

  log_print OK "Proton VPN instalado correctamente"
}
#* INSTALL_TIMESHIFT: Instala timeshift desde el repositorio de APT
INSTALL_TIMESHIFT() {
  log_print INFO "Instalando Timeshift desde repositorio oficial APT..."

  # --- Limpiar residuos de PPA inválido ---
  if ls /etc/apt/sources.list.d/teejee2008-ubuntu-ppa*.list >/dev/null 2>&1; then
    log_print INFO "Eliminando PPA obsoleto de Timeshift..."
    rm -f /etc/apt/sources.list.d/teejee2008-ubuntu-ppa*.list
  fi

  # --- Actualizar índices ---
  log_print INFO "Actualizando índices APT..."
  apt-get update -y || { log_print ERROR "apt-get update falló"; return 1; }

  # --- Instalar Timeshift desde repo oficial ---
  log_print INFO "Instalando Timeshift..."
  apt-get install -y timeshift || { log_print ERROR "No se pudo instalar Timeshift"; return 1; }

  # --- Verificación ---
  if command -v timeshift >/dev/null 2>&1; then
    log_print OK "Timeshift instalado correctamente"
  else
    log_print ERROR "Timeshift no se encuentra después de la instalación"
    return 1
  fi
}
#* OS_INFO: Brinda información del sistema
OS_INFO() {
  mkdir -p "$USER_HOME/temp/OS_Info"
  TMP_DIR_OS_INFO="$(mktemp -d "$USER_HOME/temp/OS_Info/temp.XXXXXX")"

  cleanup_osinfo() { [[ -n "${TMP_DIR_OS_INFO:-}" && -d "$TMP_DIR_OS_INFO" ]] && rm -rf "$TMP_DIR_OS_INFO"; }
  trap cleanup_osinfo EXIT

  log_print run " Recopilando información del OS..."

  {
    source /etc/os-release
    printf "%s\n" "$NAME|$VERSION|$VERSION_ID|$ID_LIKE" > "$TMP_DIR_OS_INFO/os"
    log_print verify " OS info"
  } &

  {
    CPU=$(grep "model name" /proc/cpuinfo | head -n1 | cut -d ':' -f2 | xargs)
    CORES=$(nproc)
    printf "%s\n" "$CPU|$CORES" > "$TMP_DIR_OS_INFO/cpu"
    log_print verify " CPU info"
  } &

  {
    GPU=$(lspci 2>/dev/null | grep -i 'vga\|3d\|2d' | head -n1 | cut -d ':' -f3- | xargs)
    GPU=$(printf "%s\n" "$GPU" \
      | sed -E 's/Corporation//g' \
      | sed -E 's/Core Processor//g' \
      | sed -E 's/Integrated Graphics Controller/Integrated Graphics/g' \
      | sed -E 's/\(rev [^)]+\)//g' \
      | xargs)
    printf "%s\n" "$GPU" > "$TMP_DIR_OS_INFO/gpu"
    log_print verify " GPU info"
  } &

  {
    PKG=$(dpkg -l 2>/dev/null | grep -c "^ii")
    SNAP=$(snap list 2>/dev/null | tail -n +2 | wc -l)
    printf "%s\n" "$PKG|$SNAP" > "$TMP_DIR_OS_INFO/pkg"
    log_print verify " Packages info"
  } &

  {
    MODEL=$(cat /sys/devices/virtual/dmi/id/product_name 2>/dev/null || printf "N/A")
    VENDOR=$(cat /sys/devices/virtual/dmi/id/sys_vendor 2>/dev/null || printf "")
    BIOS=$(cat /sys/devices/virtual/dmi/id/bios_version 2>/dev/null || printf "N/A")
    printf "%s\n" "$VENDOR $MODEL|$BIOS" > "$TMP_DIR_OS_INFO/hw"
    log_print verify " Hardware info"
  } &

  {
    KERNEL=$(uname -r)
    ARCH=$(uname -m)
    [[ "$ARCH" = "x86_64" ]] && OS_TYPE="64-bit" || OS_TYPE="32-bit"
    GNOME=$(gnome-shell --version 2>/dev/null | awk '{print $3}' || printf "N/A")
    SESSION=${XDG_SESSION_TYPE:-unknown}
    printf "%s\n" "$KERNEL|$OS_TYPE|$GNOME|$SESSION" > "$TMP_DIR_OS_INFO/sw"
    log_print verify " Software info"
  } &

  wait
}
GET_OSINFO() {
  case "$1" in
    user) echo "${SUDO_USER:-$(whoami)}" ;;
    host) hostname ;;
    shell) basename "$SHELL" ;;
    shell_version) "$SHELL" --version | head -n1 | awk '{print $NF}' ;;
    ram) free -h | awk '/Mem:/ {print $3 " / " $2}' ;;
    disk) df -h / | awk 'NR==2 {print $3 " / " $2 " (" $5 ")"}' ;;

    os_name) source /etc/os-release; echo "$NAME" ;;
    os_version) source /etc/os-release; echo "$VERSION" ;;
    os_type) [[ "$(uname -m)" = "x86_64" ]] && echo "64-bit" || echo "32-bit" ;;

    cpu) grep "model name" /proc/cpuinfo | head -n1 | cut -d ':' -f2 | xargs ;;
    cores) nproc ;;
    gpu) lspci 2>/dev/null | grep -i 'vga\|3d\|2d' | head -n1 | cut -d ':' -f3- | xargs \
          | sed -E 's/Corporation//g;s/Core Processor//g;s/Integrated Graphics Controller/Integrated Graphics/g;s/\(rev [^)]+\)//g' | xargs ;;
    pkg) dpkg -l 2>/dev/null | grep -c "^ii" ;;
    snap) snap list 2>/dev/null | tail -n +2 | wc -l ;;

    hw_model) cat /sys/devices/virtual/dmi/id/product_name 2>/dev/null || echo "N/A" ;;
    firmware) cat /sys/devices/virtual/dmi/id/bios_version 2>/dev/null || echo "N/A" ;;

    kernel) uname -r ;;
    gnome) gnome-shell --version 2>/dev/null | awk '{print $3}' || echo "N/A" ;;
    session) echo "${XDG_SESSION_TYPE:-unknown}" ;;
  esac
}
