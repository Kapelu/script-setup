#* Crea $USER_HOME/setup.log 
file_log() {
  exec 3>&1
  exec 1>>"$LOG_FILE" 2>&1
  clear >&3
  HEADER="          ===== START -> kapelu $(date '+%Y-%m-%d %H:%M:%S') ====="
  printf "%s\n" "$HEADER"        # 👉 va al log
  printf "%s\n" "" >&3
  printf "%s\n" "$HEADER" >&3    # 👉 se ve en pantalla
}
#* datetime: manejo de fecha y hora
datetime() {
  local fecha hora
  fecha="$(date +"%d-%m-%Y")"
  hora="$(date +"%H:%M:%S")"

  case "${1:-full}" in            #    Uso 
    date) printf "%s\n" "$fecha" ;;        # printf "%s\n" "$(datetime date)" 
    time) printf "%s\n" "$hora" ;;         # printf "%s\n" "$(datetime time)"
    *) printf "%s\n" "$fecha - $hora" ;;   # printf "%s\n" "$(datetime)"     
  esac
}
#* elapsed_time: maneja el tiempo de instalación del script
elapsed_time() {
  local start="$1"
  local elapsed=$((SECONDS - start))

  local horas=$((elapsed / 3600))
  local minutos=$(((elapsed % 3600) / 60))
  local segundos=$((elapsed % 60))

  printf "%dh:%dm:%ds" "$horas" "$minutos" "$segundos"
}
#* log_*: maneja los los en pantalla y archivo.log
log_print(){
  local type="$1"
  local msg="$2"
  local icon color text

  case "$type" in
    info)     icon="$ICON_INFO";     color="yellow" ;;
    ok)       icon="$ICON_OK";       color="yellow" ;;
    warn)     icon="$ICON_WARN";     color="yellow" ;;
    error)    icon="$ICON_ERROR";    color="yellow" ;;
    run)      icon="$ICON_RUN";      color="yellow" ;;
    verify)   icon="$ICON_VERIFY";   color="yellow" ;;
    verifail) icon="$ICON_VERIFAIL"; color="yellow" ;;
    *)        icon="";               color="yellow" ;;
  esac

  text="$msg"

  local timestamp
  timestamp="$(datetime time)"

  local console_line="              [$timestamp] ${icon}${COLOR[$color]} ${text}${COLOR[reset]}"
  local log_line="[$timestamp] ${icon} ${text}"

  {
    flock -x 200

    # consola
    printf "%b%-40s%b\n" "$console_line" >&3

    # log
    if [ -n "$LOG_FILE" ]; then
      printf "%s\n" "$log_line" >>"$LOG_FILE"
    fi
  } 200>/tmp/kapelu.lock
